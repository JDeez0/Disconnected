{
  "admin": {
    "enabled": true,
    "password": "password",
    "secret": "secret"
  },
  "engine": {
    "type": "redis",
    "redis": {
      "address": "redis:6379"
    }
  },
  "client": {
    "token": {
      "hmac_secret_key": "secret"
    },
    "allowed_origins": [
      "http://localhost:9000",
      "http://localhost:19006"
    ]
  },
  "prometheus": {
    "enabled": true,
    "instrument_http_handlers": true,
    "channel_namespace_resolution": true
  },
  "log": {
    "level": "info"
  },
  "http_server": {
    "address": "0.0.0.0"
  },
  "http_api": {
    "key": "api_key"
  },
  "channel": {
    "namespaces": [
      {
        "name": "personal",
        "history_size": 300,
        "history_ttl": "600s",
        "force_recovery": true
      }
    ]
  },
  "consumers": [],
  "push_notifications": {
    "enabled": false,
    "queue": {
      "redis": {
        "address": "redis:6379"
      }
    },
    "enabled_providers": [
      "fcm"
    ],
    "fcm": {
      "credentials_file": "fcm.json"
    }
  }
}
